{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arduino Typing Tutor",
  "version": "0.8.5",
  "identifier": "com.mehmetakar.arduinotypingtutor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["arduinotypingtutor"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUxRUIxNzVGN0REMzc3QzQKUldURWQ5TjlYeGZyNGI5MGNrNUxlMXJ3NFY4MWpWQ1NTTEhkUCt4MTRBazdaYUNKditMM1FUUEsK",
      "endpoints": [
        "https://github.com/mehmetakarim/Arduino-Typing-Tutor/releases/latest/download/latest-{{target}}-{{arch}}.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
